@app.route("/login-action", methods=["POST"])
def login_action():
    data = request.json
    email = data.get("email")
    password = data.get("password")

    conn = get_db_connection()
    cursor = conn.cursor(dictionary=True)
    cursor.execute("SELECT * FROM users WHERE email=%s AND password_hash=%s", (email, password))
    user = cursor.fetchone()
    cursor.close()
    conn.close()

    if not user:
        return jsonify({"status": "fail"}), 401

    # Save email temporarily for OTP step
    session["pending_email"] = email

    print(f"OTP for {email}: 1234")

    return jsonify({"status": "otp_required"})









# -------------------------
# LOGIN STEP 2 — OTP VERIFY
# -------------------------
@app.route("/verify-otp-action", methods=["POST"])
def verify_otp():
    data = request.json
    otp = data.get("otp")
    email = session.get("pending_email")

    if otp != "1234" or not email:
        return jsonify({"success": False})

    conn = get_db_connection()
    cursor = conn.cursor(dictionary=True)
    cursor.execute("SELECT * FROM users WHERE email=%s", (email,))
    user = cursor.fetchone()
    cursor.close()
    conn.close()

    session["user_id"] = user["user_id"]
    session["role"] = user["role"]
    session.pop("pending_email", None)

    redirect_url = "/student_portal" if user["role"] == "student" else "/professor_portal"

    return jsonify({"success": True, "redirect": redirect_url})

