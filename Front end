@app.route("/create-assignment", methods=["POST"])
def create_assignment():
    if "user_id" not in session or session["role"] != "professor":
        return redirect("/")

    title = request.form["title"]
    deadline = request.form["deadline"]
    course_id = request.form.get("course_id")

    conn = get_db_connection()
    cursor = conn.cursor()
    cursor.execute("INSERT INTO assignments (course_id, title, deadline) VALUES (%s, %s, %s)",
                   (course_id, title, deadline))
    conn.commit()
    cursor.close()
    conn.close()

    return redirect("/professor_portal")


