@app.route("/upload_assignment", methods=["POST"])
def upload_assignment():
    if "user_id" not in session or session["role"] != "student":
        return redirect("/")

    student_id = session["user_id"]
    assignment_id = request.form["assignment_id"]
    file = request.files["file"]

    filename = secure_filename(file.filename)
    file_path = os.path.join(app.config["UPLOAD_FOLDER"], filename)
    file.save(file_path)

    # Check late submission
    conn = get_db_connection()
    cursor = conn.cursor(dictionary=True)

    cursor.execute("SELECT deadline FROM assignments WHERE assignment_id=%s", (assignment_id,))
    deadline = cursor.fetchone()["deadline"]

    is_late = False
    cursor.execute("SELECT NOW() > %s AS late", (deadline,))
    is_late = cursor.fetchone()["late"]

    # Insert submission
    cursor.execute("""
        INSERT INTO submissions (assignment_id, student_id, file_path, is_late)
        VALUES (%s, %s, %s, %s)
    """, (assignment_id, student_id, file_path, is_late))

    conn.commit()
    cursor.close()
    conn.close()

    return redirect("/student_portal")


