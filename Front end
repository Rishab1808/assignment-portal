@app.route("/student_portal")
def student_portal():
    if 'user_id' not in session or session.get('role') != 'student':
        return redirect('/')

    student_id = session["user_id"]

    conn = get_db_connection()
    cursor = conn.cursor(dictionary=True)

    # 1. Student courses (based on assignments assigned to them)
    cursor.execute("""
        SELECT DISTINCT c.course_id, c.course_name
        FROM courses c
        JOIN assignments a ON c.course_id = a.course_id
    """)
    courses = cursor.fetchall()

    # 2. Upcoming assignments (deadline not passed + not submitted)
    cursor.execute("""
        SELECT a.assignment_id, a.title, a.deadline, c.course_name
        FROM assignments a
        JOIN courses c ON a.course_id = c.course_id
        WHERE a.deadline > NOW()
        AND a.assignment_id NOT IN (
            SELECT assignment_id FROM submissions WHERE student_id=%s
        )
        ORDER BY a.deadline ASC
    """, (student_id,))
    upcoming = cursor.fetchall()

    # 3. Overdue assignments (deadline passed + not submitted)
    cursor.execute("""
        SELECT a.assignment_id, a.title, a.deadline, c.course_name
        FROM assignments a
        JOIN courses c ON a.course_id = c.course_id
        WHERE a.deadline < NOW()
        AND a.assignment_id NOT IN (
            SELECT assignment_id FROM submissions WHERE student_id=%s
        )
        ORDER BY a.deadline ASC
    """, (student_id,))
    overdue = cursor.fetchall()

    # 4. Submission History
    cursor.execute("""
        SELECT s.submission_id, s.submitted_at, s.is_late, s.score,
               a.title, a.max_score, c.course_name
        FROM submissions s
        JOIN assignments a ON s.assignment_id = a.assignment_id
        JOIN courses c ON a.course_id = c.course_id
        WHERE s.student_id = %s
        ORDER BY s.submitted_at DESC
    """, (student_id,))
    history = cursor.fetchall()

    cursor.close()
    conn.close()

    return render_template(
        "student.html",
        courses=courses,
        upcoming=upcoming,
        overdue=overdue,
        history=history
    )




@app.route("/professor_portal")
def professor_portal():
    if 'user_id' not in session or session.get('role') != 'professor':
        return redirect('/')

