<!DOCTYPE html>
<html>
<head>
    <title>Student Portal</title>
    <style>
        body { font-family: sans-serif; padding: 20px; }
        .card { border: 1px solid #ccc; padding: 20px; border-radius: 8px; max-width: 500px; }
        button { background-color: #28a745; color: white; border: none; padding: 10px 15px; cursor: pointer; }
    </style>
</head>
<body>
    <h1>Welcome Student</h1>
    
    <div class="card">
        <h3>Submit Assignment</h3>
        <p><strong>Assignment:</strong> Data Structures (ID: 1)</p>
        
        <form action="/upload-action" method="POST" enctype="multipart/form-data">
            
            <input type="hidden" name="assignment_id" value="1">
            
            <label>Choose File:</label><br>
            <input type="file" name="file" required><br><br>
            
            <button type="submit">Upload Now</button>
        </form>
    </div>

</body>
</html>
